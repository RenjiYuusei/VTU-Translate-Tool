<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme -->
    <style name="Theme.VTUTranslate" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/accent</item>
        <item name="colorSecondaryVariant">@color/accent</item>
        <item name="colorOnSecondary">@color/white</item>
        <!-- Status bar color -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Text appearance -->
        <item name="textAppearanceHeadline6">@style/TextAppearance.VTUTranslate.Headline6</item>
        <item name="textAppearanceBody1">@style/TextAppearance.VTUTranslate.Body1</item>
        <!-- Enable window content transitions -->
        <item name="android:windowActivityTransitions">true</item>
    </style>

    <!-- Text appearance styles -->
    <style name="TextAppearance.VTUTranslate.Headline6" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">@color/primary_text</item>
    </style>

    <style name="TextAppearance.VTUTranslate.Body1" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/secondary_text</item>
    </style>
</resources> 