# Edit at https://www.toptal.com/developers/gitignore?templates=android,gradle,kotlin,jetpackcompose

### Android ###
# Built application files
*.apk
*.aab
*.ap_

# Files for the ART/Dalvik VM
*.dex

# Built C/C++ libraries
/app/build/intermediates/cmake/debug/obj
/app/build/intermediates/cmake/release/obj

# Android Studio Navigation editor files
.navigation/

# Android Studio captures folder
captures/

# HPROF dumps
*.hprof

# Built folder
build/

# Local configuration file (sdk path, etc)
local.properties

# Log Files
*.log

# Keystore files
*.jks
*.keystore

# Signing configs
signing.properties

### AndroidStudio ###
# User-specific stuff
.idea/caches/
.idea/libraries/
.idea/modules.xml
.idea/workspace.xml
.idea/navEditor.xml
.idea/assetWizardSettings.xml

# Generated files
.idea/generated/

# IntelliJ
*.iml

# Patch files
*.patch

# Google services file
google-services.json

# Local test results
/build/reports/tests/

# Android Studio profiling data
.idea/profiler/

# Editor-based settings
.idea/copyright/
.ideais.xml
.idea/markdown-navigator/
.idea/markdown-navigator.xml
.idea/vcs.xml

# Other
.DS_Store

### Gradle ###
.gradle
build/

# Ignore Gradle GUI config
gradle-app.setting

# Avoid ignoring Gradle wrapper jar file (.jar files are usually ignored)
!gradle-wrapper.jar

# Avoid ignoring Gradle wrapper properties file (.properties files are usually ignored)
!gradle/wrapper/gradle-wrapper.properties

# Exclude Gradle build scans plugin configuration file
.gradlescan/

# Lockfiles
*.lockfile

### JetpackCompose ###
# Built by Android Studio
.idea/inspectionProfiles/

### Kotlin ###
# Compiled class files
*.class

# Compiled sketch files
*.sketches

# Package files
*.jar
*.war
*.ear
*.zip
*.tar.gz
*.rar

# Log files
*.log

# Scoped functions
*.run.xml
*.ws.xml

# kotlin-jupyter-api
.jupyter_kotlin/

# Build directory
/build/

# Toplevel project .idea folder (if it exists)
.idea/

# End of https://www.toptal.com/developers/gitignore/api/android,gradle,kotlin,jetpackcompose
